# =============================================================================
# xismarket — PRODUCTION environment template
#
#   cp .env.production.example .env
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml run --rm app php artisan key:generate
#   # then fill in every CHANGE_ME below
#
# Anything marked CHANGE_ME must be set before going live.
# =============================================================================

APP_NAME=xismarket
APP_ENV=production
APP_KEY=                       # CHANGE_ME — run `php artisan key:generate`
APP_DEBUG=false
APP_URL=https://CHANGE_ME.example.com

# --- Caddy / TLS (read by docker-compose.prod.yml) ---------------------------
APP_DOMAIN=CHANGE_ME.example.com    # the bare domain Caddy serves (no scheme)
ACME_EMAIL=admin@CHANGE_ME.example.com   # for Let's Encrypt expiry notices

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# --- Database (the `mysql` compose service) ----------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=xismarket
DB_USERNAME=xismarket
DB_PASSWORD=CHANGE_ME_strong_password
DB_ROOT_PASSWORD=CHANGE_ME_strong_root_password

# --- Redis-backed sessions, cache and queue (the `redis` compose service) ----
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Mail (required for receipts & password resets) --------------------------
# Switch MAIL_MAILER to smtp and fill the host/credentials.
MAIL_MAILER=smtp
MAIL_HOST=CHANGE_ME.smtp.example.com
MAIL_PORT=587
MAIL_SCHEME=smtp
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_TIMEOUT=10
MAIL_FROM_ADDRESS="orders@CHANGE_ME.example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- SMS alerts (optional) ---------------------------------------------------
# New-order alerts always email the store owner/admins. To also text the store
# phone, set SMS_PROVIDER to a real driver and fill its credentials. 'log' (the
# default) does not send — it only records the message to the application log.
SMS_PROVIDER=log
SMS_FROM=
# TERMII_API_KEY=
# TWILIO_SID=
# TWILIO_TOKEN=
# TWILIO_FROM=

# --- AI product-image tools (optional) ---------------------------------------
# Leave IMAGE_AI_KEY blank to keep the AI buttons disabled.
IMAGE_AI_PROVIDER=gemini
IMAGE_AI_KEY=
IMAGE_AI_MODEL=gemini-2.5-flash-image

# Show this store at the root URL (sales.nimisystems.com) instead of admin login
STOREFRONT_DEFAULT_STORE=
