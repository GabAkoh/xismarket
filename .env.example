APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail: "log" writes emails to the app log (local dev). For real delivery set
# MAIL_MAILER=smtp and fill in your provider's SMTP details below.
MAIL_MAILER=log

# SMTP host, e.g. mail.yourdomain.com / smtp.sendgrid.net / smtp.gmail.com
MAIL_HOST=smtp.example.com
# 587 -> MAIL_SCHEME=smtp (STARTTLS)   |   465 -> MAIL_SCHEME=smtps (SSL)
MAIL_PORT=587
MAIL_SCHEME=smtp
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_TIMEOUT=10
# Sender shown to recipients — must be allowed to send from MAIL_HOST (SPF/DKIM).
MAIL_FROM_ADDRESS="orders@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Verify after configuring:  php artisan mail:test you@example.com

# AI product-image tools (background removal, recolor, side views, model shots).
# Leave IMAGE_AI_KEY blank to keep the feature disabled (the buttons show a
# "not configured" notice). Provider 'gemini' uses Google's Gemini image model;
# 'stub' echoes the source image (local testing only).
IMAGE_AI_PROVIDER=gemini
IMAGE_AI_KEY=
IMAGE_AI_MODEL=gemini-2.5-flash-image

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Set to a store slug to show that store's storefront at the root URL ("/")
# instead of the admin login.
STOREFRONT_DEFAULT_STORE=
